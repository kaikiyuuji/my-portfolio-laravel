# =============================================================
# APLICAÇÃO
# =============================================================

APP_NAME="Meu Portfolio"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Sao_Paulo
APP_URL=http://localhost:8000

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# =============================================================
# LOG
# =============================================================

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# =============================================================
# BANCO DE DADOS
# =============================================================
# Default: SQLite (rodar do zero sem subir um servidor de banco).
# Basta `touch database/database.sqlite` e rodar as migrations.
#
# Para usar MySQL local, troque DB_CONNECTION=mysql e descomente o bloco abaixo.
# (No Windows use DB_HOST=127.0.0.1, nunca 'localhost'.)

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=portfolio
# DB_USERNAME=root
# DB_PASSWORD=

# =============================================================
# SESSÃO
# =============================================================

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

# =============================================================
# CACHE
# =============================================================

CACHE_STORE=database
CACHE_PREFIX=portfolio_

# =============================================================
# FILAS / BROADCAST
# =============================================================

BROADCAST_CONNECTION=log
QUEUE_CONNECTION=database

# =============================================================
# REDIS (opcional)
# =============================================================

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# =============================================================
# ARMAZENAMENTO DE ARQUIVOS
# =============================================================
# 'local'/'public' → disco local (suficiente para desenvolvimento).
# O disco/driver de produção (ex: S3) será decidido junto da arquitetura.

FILESYSTEM_DISK=public

# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=
# AWS_USE_PATH_STYLE_ENDPOINT=false

# =============================================================
# E-MAIL
# =============================================================
# 'log' grava os e-mails em storage/logs (ideal para desenvolvimento).

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# =============================================================
# VITE / FRONTEND
# =============================================================
# VITE_* fica exposto ao JS do cliente. NUNCA coloque segredos aqui.

VITE_APP_NAME="${APP_NAME}"
VITE_APP_URL="${APP_URL}"

# =============================================================
# PORTFOLIO — CONFIGURAÇÕES CUSTOMIZADAS
# =============================================================

PORTFOLIO_DEFAULT_LOCALE=pt
PORTFOLIO_ALLOW_REGISTRATION=false
