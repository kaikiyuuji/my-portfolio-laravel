# =============================================================
# APLICAÇÃO
# =============================================================
# Em produção: APP_ENV=production e APP_DEBUG=false são obrigatórios.
# APP_DEBUG=true em produção expõe stack traces com paths e credenciais.

APP_NAME="Meu Portfolio"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=America/Sao_Paulo
APP_URL=https://seudominio.com.br

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# =============================================================
# LOG
# =============================================================
# Em produção use LOG_LEVEL=error. 'debug' apenas em local/staging.

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# =============================================================
# BANCO DE DADOS
# =============================================================
# Em produção (Docker Compose): DB_HOST = nome do serviço (ex: 'mysql').
# Local (XAMPP/Windows): DB_HOST=127.0.0.1 (nunca 'localhost' no Windows).

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=portfolio
DB_USERNAME=portfolio_user
DB_PASSWORD=__GERAR__

# =============================================================
# SESSÃO
# =============================================================
# 'database' sobrevive a deploys (volume persistente do MySQL).
# SESSION_SECURE_COOKIE=true exige HTTPS — manter true em produção.

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=seudominio.com.br
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# =============================================================
# CACHE
# =============================================================

CACHE_STORE=database
CACHE_PREFIX=portfolio_

# =============================================================
# FILAS
# =============================================================

BROADCAST_CONNECTION=log
QUEUE_CONNECTION=database

# =============================================================
# REDIS (opcional — caso migre cache/queue para redis)
# =============================================================

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# =============================================================
# ARMAZENAMENTO DE ARQUIVOS
# =============================================================
# 'public' → storage local do container (NÃO persiste entre deploys).
# 's3'     → DO Spaces ou AWS S3 (recomendado para produção).

FILESYSTEM_DISK=s3

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=nyc3
AWS_BUCKET=
AWS_ENDPOINT=https://nyc3.digitaloceanspaces.com
AWS_USE_PATH_STYLE_ENDPOINT=false

# =============================================================
# E-MAIL
# =============================================================
# Para o formulário de contato (futuro). Configure SMTP/Mailgun/Resend.

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=postmaster@seudominio.com.br
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="portfolio@seudominio.com.br"
MAIL_FROM_NAME="${APP_NAME}"

# =============================================================
# SEGURANÇA — PROXY/SANCTUM
# =============================================================
# TRUSTED_PROXIES=* exigido quando atrás de Nginx/load balancer.

TRUSTED_PROXIES=*
SANCTUM_STATEFUL_DOMAINS=seudominio.com.br

# =============================================================
# VITE / FRONTEND
# =============================================================
# VITE_* fica exposto ao JS do cliente. NUNCA coloque segredos aqui.

VITE_APP_NAME="${APP_NAME}"
VITE_APP_URL="${APP_URL}"

# =============================================================
# PORTFOLIO — CONFIGURAÇÕES CUSTOMIZADAS
# =============================================================

PORTFOLIO_DEFAULT_LOCALE=pt
PORTFOLIO_ALLOW_REGISTRATION=false
